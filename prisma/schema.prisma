generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPERADMIN
  ADMIN
  OPERATOR
  RACER
  TEAM_MANAGER
}

enum Status {
  ACTIVE
  INACTIVE
  BANNED
  DELETED
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  PRO
  ELITE
}

enum VehicleStatus {
  AVAILABLE
  RESERVED
  MAINTENANCE
  DISABLED
}

enum VehicleControlType {
  RC_CONTROLLER
  FPV
  STEERING_WHEEL
  MOBILE_APP
  SIMULATOR
}

enum VehicleMaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

model User {
  id           Int      @id @default(autoincrement())
  fullName     String
  phone        String   @unique
  email        String?  @unique
  passwordHash String
  role         UserRole @default(RACER)
  status       Status   @default(ACTIVE)

  lastLoginAt DateTime?
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile      Profile?
  userSessions UserSession[]

  @@index([role])
  @@index([status])
  @@index([deletedAt])
}

model Profile {
  id              Int              @id @default(autoincrement())
  userId          Int              @unique
  nickname        String?
  avatarUrl       String?
  bio             String?
  experienceLevel ExperienceLevel?
  isCompleted     Boolean          @default(false)
  status          Status           @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([experienceLevel])
  @@index([userId])
  @@index([status])
}

model UserSession {
  id Int @id @default(autoincrement())

  userId           Int
  refreshTokenHash String

  ipAddress  String?
  userAgent  String?
  deviceName String?

  expiresAt DateTime
  revokedAt DateTime?
  status    Status    @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([id, userId])
  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([status])
}

model RacingCategory {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?
  speedRange  String?
  trackType   String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicles Vehicle[]

  @@index([isActive])
  @@index([sortOrder])
}

model Vehicle {
  id         Int @id @default(autoincrement())
  categoryId Int

  name     String
  slug     String  @unique
  imageUrl String?

  topSpeedKmh        Int?
  batteryLifeMinutes Int?
  controlType        VehicleControlType?
  difficulty         ExperienceLevel?
  status             VehicleStatus       @default(AVAILABLE)

  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category     RacingCategory       @relation(fields: [categoryId], references: [id])
  maintenances VehicleMaintenance[]

  @@index([categoryId])
  @@index([status])
  @@index([difficulty])
  @@index([controlType])
  @@index([isActive])
  @@index([sortOrder])
}

model VehicleMaintenance {
  id        Int @id @default(autoincrement())
  vehicleId Int

  title  String
  reason String?
  status VehicleMaintenanceStatus @default(OPEN)

  startedAt  DateTime?
  resolvedAt DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([status])
  @@index([startedAt])
  @@index([resolvedAt])
}
